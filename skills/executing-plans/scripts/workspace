#!/usr/bin/env bash
# Resolve and ensure the working-tree directory executing-plans uses for its
# short-lived artifacts: review packages and the progress ledger. Print the
# directory's absolute path.
#
# The workspace lives in the working tree (not under .git/) because Claude Code
# treats .git/ as a protected path and denies agent writes there. A
# self-ignoring .gitignore keeps the workspace out of `git status` and out of
# accidental commits without modifying any tracked file.
#
# Single source of truth for the workspace location, so review-package and the
# ledger cannot drift to different directories.
#
# Usage: workspace
set -euo pipefail

root=$(git rev-parse --show-toplevel)
dir="$root/.superpowers/exec"
mkdir -p "$dir"
printf '*\n' > "$dir/.gitignore"
cd "$dir" && pwd
