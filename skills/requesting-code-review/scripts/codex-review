#!/usr/bin/env bash
# Cross-model adversarial review via the `codex` CLI — no plugin required.
#
# Shells out to `codex exec` (headless) with a read-only sandbox and a JSON
# output schema, so a *different* model (Codex / GPT-5.x) reviews a spec, a
# plan, or a code diff and returns structured findings on stdout. Depends only
# on `codex` being installed and on PATH (plus `git` for code diffs). Works from
# any agent that can run a shell.
#
# Two lenses (same plumbing, different prompt template):
#   --lens adversarial  (default)  holistic review; spec | plan | code.
#   --lens rubric                  codex-native patch-bug rubric; code-only, P0-P3.
# Complementary — run both and merge with `review-merge`; loop in review-loop.md.
#
# Usage:
#   codex-review --kind spec --file <spec> [--focus "..."] [--model M]
#   codex-review --kind plan --file <plan> [--design <spec>] [--focus "..."] [--model M]
#   codex-review --kind code [--base <ref>] [--focus "..."] [--model M]
#   codex-review --lens rubric [--base <ref>] [--model M]      # code-only
#
# --design <spec> (plan only): the originating design/spec. With it, the review
#   verifies the plan covers the design (and adds nothing it didn't); without it,
#   the review checks executability only and does NOT claim to assess coverage.
#
# Output: JSON matching the lens's schema on stdout. Exit codes: 0 = review
#   produced; 2 = bad usage; 3 = codex CLI not found (caller degrades and skips).
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"

kind="" file="" base="" focus="" model="" lens="adversarial" design=""
while [ $# -gt 0 ]; do
  case "$1" in
    --kind)   kind="$2"; shift 2 ;;
    --file)   file="$2"; shift 2 ;;
    --design) design="$2"; shift 2 ;;
    --base)   base="$2"; shift 2 ;;
    --focus)  focus="$2"; shift 2 ;;
    --model)  model="$2"; shift 2 ;;
    --lens)   lens="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "codex-review: unknown argument: $1" >&2; exit 2 ;;
  esac
done

case "$lens" in
  adversarial|rubric) ;;
  *) echo "codex-review: --lens must be 'adversarial' or 'rubric'" >&2; exit 2 ;;
esac

# The rubric lens is the codex-native patch-bug reviewer — code diffs only.
if [ "$lens" = rubric ]; then
  [ -z "$kind" ] && kind="code"
  [ "$kind" = code ] || { echo "codex-review: --lens rubric is code-only (got --kind $kind)" >&2; exit 2; }
fi

[ -n "$kind" ] || { echo "codex-review: --kind is required (spec|plan|code)" >&2; exit 2; }

if ! command -v codex >/dev/null 2>&1; then
  echo "codex CLI not found on PATH — skip the cross-model review (degradable)" >&2
  exit 3
fi

# Select prompt template + output schema by lens.
if [ "$lens" = rubric ]; then
  PROMPT_TEMPLATE="$HERE/rubric.md"
  SCHEMA="$HERE/codex-review-rubric.schema.json"
else
  PROMPT_TEMPLATE="$HERE/codex-review-prompt.md"
  SCHEMA="$HERE/codex-review.schema.json"
fi

# Build the review input + the lens-specific lead (header / user message).
case "$kind" in
  spec|plan)
    [ "$lens" = adversarial ] || { echo "codex-review: $kind needs --lens adversarial" >&2; exit 2; }
    [ -n "$file" ] || { echo "codex-review: --kind $kind needs --file <path>" >&2; exit 2; }
    [ -f "$file" ] || { echo "codex-review: no such file: $file" >&2; exit 2; }
    # Number every line so findings can cite line ranges precisely.
    file_numbered="$(awk '{ printf "%6d\t%s\n", NR, $0 }' "$file")"
    if [ "$kind" = spec ]; then
      input="$file_numbered"
      label="a spec DOCUMENT (\`$file\`), not application code"
      attack="Weight: attack the design's soundness — vague or unfalsifiable acceptance criteria, unstated assumptions, failure modes it ignores, missing scope bounds / non-goals, hidden dependencies, and decisions that won't survive real-world load."
    elif [ -n "$design" ]; then
      # Plan + its originating design: the review can genuinely check coverage.
      [ -f "$design" ] || { echo "codex-review: no such design file: $design" >&2; exit 2; }
      design_numbered="$(awk '{ printf "%6d\t%s\n", NR, $0 }' "$design")"
      input="===== ORIGINATING DESIGN (\`$design\`) =====
${design_numbered}

===== IMPLEMENTATION PLAN (\`$file\`) =====
${file_numbered}"
      label="an IMPLEMENTATION PLAN (\`$file\`) and its ORIGINATING DESIGN (\`$design\`), not application code"
      attack="Weight, in order: (1) COVERAGE — every goal, acceptance criterion, and non-goal in the DESIGN must be honored by the PLAN. Flag each design requirement no task covers, and each plan task that serves no design requirement (gold-plating). (2) EXECUTABILITY — tasks that cannot be executed as written, missing failure/edge handling, ordering and dependency hazards, missing rollback, unverified boundary assumptions. Each block is line-numbered from its own line 1; cite the DESIGN or PLAN path in \`file\`."
    else
      # Plan with no design supplied: it is dishonest to claim coverage we can't see.
      input="$file_numbered"
      label="an IMPLEMENTATION PLAN (\`$file\`) WITHOUT its originating design, not application code"
      attack="Weight: attack the plan's executability — tasks that cannot be executed as written, missing failure/edge handling, ordering and dependency hazards, missing rollback, and unverified boundary assumptions. No design was provided, so do NOT assess coverage against the design — you cannot see it."
      echo "codex-review: note — no --design given; this plan review checks executability only, not coverage against the originating design" >&2
    fi
    header="The material under review is ${label}.
${attack}"
    ;;
  code)
    if [ -n "$base" ]; then
      input="$(git diff "$base"...HEAD)"
    else
      input="$(git diff --cached; git diff)"
    fi
    [ -n "$input" ] || { echo "codex-review: empty code diff (nothing to review)" >&2; exit 2; }
    if [ "$lens" = rubric ]; then
      # The rubric is the system prompt; this is its "user message". The diff is
      # pre-supplied on stdin (codex appends a <stdin> block) — the deterministic,
      # diff-scoped local option (no repo spelunking). Mirrors ReviewTarget::Commit.
      header="Review the code changes provided as a git diff in the <stdin> block below. The diff IS the patch under review — treat every added/changed line as 'introduced by this change'. Provide prioritized, actionable findings per the guidelines."
    else
      label="a CODE CHANGE (git diff)"
      attack="Weight: prioritize expensive, dangerous, hard-to-detect failures — auth / permissions / trust boundaries; data loss, corruption, irreversible state; rollback safety, retries, partial failure, idempotency; races, ordering, stale state; empty / null / timeout / degraded-dependency behavior; version skew, schema drift, migration hazards; observability gaps that hide failure."
      header="The material under review is ${label}.
${attack}"
    fi
    ;;
  *)
    echo "codex-review: --kind must be spec, plan, or code" >&2; exit 2 ;;
esac

[ -n "$focus" ] && header="${header}
User focus (weight heavily): ${focus}"

# Compose the prompt: lens lead/header + the lens's instruction template.
prompt="${header}

$(cat "$PROMPT_TEMPLATE")"

outfile="$(mktemp -t codex-review.XXXXXX)"
trap 'rm -f "$outfile"' EXIT

model_args=()
if [ -n "$model" ]; then
  [ "$model" = spark ] && model="gpt-5.3-codex-spark"
  model_args=(--model "$model")
fi

# Headless, read-only, schema-constrained. The review material is piped on stdin
# (codex appends it as a <stdin> block); the final JSON lands in $outfile.
printf '%s' "$input" | codex exec \
  --color never \
  --sandbox read-only \
  --skip-git-repo-check \
  --ephemeral \
  "${model_args[@]}" \
  --output-schema "$SCHEMA" \
  --output-last-message "$outfile" \
  "$prompt" >/dev/null

if [ ! -s "$outfile" ]; then
  echo "codex-review: codex produced no output (auth or run error — check \`codex login status\`)" >&2
  exit 1
fi
cat "$outfile"
